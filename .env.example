# ──────────────────────────────────────────────
# REQUIRED
# ──────────────────────────────────────────────

# Claude API key (get from https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ──────────────────────────────────────────────
# OPTIONAL — Google Sheet & Drive names
# ──────────────────────────────────────────────

# Name of your Google Sheet (default: ORDER SHEET)
# SHEET_NAME=ORDER SHEET

# Tab name inside the sheet (default: Orders)
# TAB_NAME=Orders

# Google Drive folder name for receipt uploads (default: receipts)
# DRIVE_FOLDER_NAME=receipts

# ──────────────────────────────────────────────
# OPTIONAL — Tax configuration
# ──────────────────────────────────────────────

# Default is Quebec (GST 5% + QST 9.975%)
# For Ontario: TAX1_NAME=HST, TAX1_RATE=13%, remove TAX2 lines
# For Alberta: TAX1_NAME=GST, TAX1_RATE=5%, remove TAX2 lines

# TAX1_NAME=GST
# TAX1_RATE=5%
# TAX2_NAME=QST
# TAX2_RATE=9.975%

# ──────────────────────────────────────────────
# OPTIONAL — Agent settings
# ──────────────────────────────────────────────

# Claude model to use (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514

# How far back to look on first run, in hours (default: 168 = 7 days)
# LOOKBACK_HOURS=168

# How often to run, in hours (default: 12)
# RUN_INTERVAL_HOURS=12

# Set to true if your Google Sheet uses comma as decimal separator (French locale)
# DECIMAL_COMMA=false

# ──────────────────────────────────────────────
# OPTIONAL — Amazon SP-API (for auto ASIN matching)
# ──────────────────────────────────────────────
# Only needed if you want receipt product names auto-matched to your Amazon ASINs.
# The agent works perfectly fine without these — you just won't get auto ASIN fill.

# SP_API_CLIENT_ID=amzn1.application-oa2-client.your-client-id
# SP_API_CLIENT_SECRET=your-client-secret
# SP_API_REFRESH_TOKEN=your-refresh-token
